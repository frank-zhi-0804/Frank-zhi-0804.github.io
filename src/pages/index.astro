---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>关于我 | 阮成智的博客</title>
</head>
<body>

<canvas id="canvas"></canvas>

<Header />

<main style="max-width: 700px; margin: 0 auto; padding: 4rem 2rem;">
  <div>
    <h1 style="color: #fff;">你好，我是阮成智</h1>
    <p style="color: #e2e8f0;">华中师范大学计算机学院大一学生，热爱编程与开发，正在朝着 AI + 全栈工程师的方向努力。</p>

    <h2 style="color: #fff;">关于我</h2>
    <p style="color: #e2e8f0;">粗略了解 C 语言、Vue3、Node.js 等技术，喜欢用代码实现想法，也在学习全栈开发与算法知识。平时也享受从 0 到 1 搭建产品的过程。</p>

    <h2 style="color: #fff;">技能方向</h2>
    <div style="margin: 1rem 0;">
      <span style="background: rgba(120,180,255,0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; margin: 0 6px 6px 0; display: inline-block;">C / C++</span>
      <span style="background: rgba(120,180,255,0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; margin: 0 6px 6px 0; display: inline-block;">Vue3</span>
      <span style="background: rgba(120,180,255,0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; margin: 0 6px 6px 0; display: inline-block;">HTML / CSS</span>
      <span style="background: rgba(120,180,255,0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; margin: 0 6px 6px 0; display: inline-block;">JavaScript</span>
      <span style="background: rgba(120,180,255,0.15); color: #93c5fd; padding: 6px 12px; border-radius: 6px; margin: 0 6px 6px 0; display: inline-block;">Astro</span>
    </div>

    <h2 style="color: #fff;">小目标</h2>
    <p style="color: #e2e8f0;">打好计算机基础，提升工程能力，持续输出技术内容，未来成为一名靠谱的全栈开发者。</p>
  </div>
</main>

<Footer />

<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let particles = [];
let ripples = [];
let mouse = { x: null, y: null };

window.addEventListener('mousemove', (e) => {
  mouse.x = e.x;
  mouse.y = e.y;
});

window.addEventListener('click', (e) => {
  ripples.push({ x: e.x, y: e.y, r: 0, opacity: 1 });
});

class Particle {
  constructor() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * canvas.height;
    this.size = Math.random() * 2.5 + 1;
    this.speedX = Math.random() * 0.5 - 0.25;
    this.speedY = Math.random() * 0.5 - 0.25;
  }
  update() {
    this.x += this.speedX;
    this.y += this.speedY;
    if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
    if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;

    const dx = this.x - mouse.x;
    const dy = this.y - mouse.y;
    const dist = Math.hypot(dx, dy);
    if (dist < 120) {
      this.x -= dx * 0.02;
      this.y -= dy * 0.02;
    }
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(120, 180, 255, 0.65)';
    ctx.fill();
  }
}

function init() {
  particles = [];
  for (let i = 0; i < 200; i++) particles.push(new Particle());
}

function animate() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  particles.forEach(p => { p.update(); p.draw(); });
  ripples.forEach((r, i) => {
    r.r += 1.2;
    r.opacity -= 0.015;
    if (r.opacity <= 0) ripples.splice(i, 1);
    ctx.beginPath();
    ctx.arc(r.x, r.y, r.r, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(120, 180, 255, ${r.opacity})`;
    ctx.lineWidth = 2;
    ctx.stroke();
  });
  requestAnimationFrame(animate);
}

init();
animate();

window.addEventListener('resize', () => {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  init();
});
</script>

<style>
body {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
  margin: 0;
  padding: 0;
}

#canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 999;
}
</style>

</body>
</html>